{
  "name": "codex-cli-discord",
  "version": "0.3.0",
  "description": "A tiny Discord bot that bridges Codex CLI or Claude Code into Discord threads.",
  "license": "MIT",
  "author": "ATou",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "start:shared": "node scripts/start-instance.mjs shared",
    "start:codex": "node scripts/start-instance.mjs codex",
    "start:claude": "node scripts/start-instance.mjs claude",
    "dev": "node --watch src/index.js",
    "dev:codex": "BOT_PROVIDER=codex node --watch src/index.js",
    "dev:claude": "BOT_PROVIDER=claude node --watch src/index.js",
    "setup-hooks": "git config core.hooksPath .githooks",
    "check:atomic": "node scripts/check-atomic-commit.mjs --staged",
    "check:reply-fallback": "node scripts/check-safe-reply.mjs",
    "test:progress": "node --test test/progress-utils.test.mjs test/progress-milestones.test.mjs test/codex-event-utils.test.mjs test/discord-message-splitter.test.mjs test/provider-utils.test.mjs test/bot-instance-utils.test.mjs test/env-loader.test.mjs",
    "release:patch": "node scripts/cut-release.mjs patch",
    "release:minor": "node scripts/cut-release.mjs minor",
    "release:major": "node scripts/cut-release.mjs major",
    "run:auto-upgrade": "node scripts/codex-auto-upgrade.mjs",
    "install:auto-upgrade": "node scripts/install-codex-auto-upgrade.mjs",
    "patch-ws": "node scripts/patch-discord-ws.mjs",
    "postinstall": "node scripts/patch-discord-ws.mjs"
  },
  "dependencies": {
    "discord.js": "^14.19.3",
    "dotenv": "^16.6.1",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "socks-proxy-agent": "^8.0.5",
    "undici": "^6.21.3"
  }
}
