# Discord bot token (Developer Portal)
DISCORD_TOKEN=

# Codex auth (if your codex provider needs it)
# Most OpenAI-compatible providers use OPENAI_API_KEY.
OPENAI_API_KEY=

# Comma-separated. Leave empty to allow all channels.
ALLOWED_CHANNEL_IDS=

# Comma-separated. Leave empty to allow everyone.
ALLOWED_USER_IDS=

# Security profile: auto | solo | team | public
# auto: DM -> solo; guild channel with @everyone ViewChannel -> public; else team
SECURITY_PROFILE=auto

# Mention-only mode for normal messages.
# Leave empty to use profile default (solo/team=false, public=true).
MENTION_ONLY=

# Max queued prompts per channel (not counting the running one).
# 0 = unlimited. Leave empty to use profile default (solo=0, team/public=20).
MAX_QUEUE_PER_CHANNEL=

# Enable !config command (default off)
ENABLE_CONFIG_CMD=false

# Allowlist for !config key=value (comma-separated key names).
# Set "*" to allow all keys (not recommended).
CONFIG_ALLOWLIST=personality,model_reasoning_effort,model_auto_compact_token_limit

# Per-thread workspaces are created under this folder.
WORKSPACE_ROOT=./workspaces

# Default Codex model (optional, e.g. gpt-5.3-codex)
DEFAULT_MODEL=

# Codex CLI command or absolute path.
# Useful on new devices / pm2 / launchd / systemd when PATH is incomplete.
# Example (macOS Homebrew): /opt/homebrew/bin/codex
# Example (Windows): C:\\Users\\<you>\\AppData\\Local\\Programs\\Codex\\codex.exe
CODEX_BIN=codex

# Slash command prefix (default: cx, e.g. /cx_status, /cx_reset)
SLASH_PREFIX=cx

# safe | dangerous
DEFAULT_MODE=safe

# Hard timeout for a single codex run (ms).
# Set 0 to disable hard timeout (recommended for long-running tasks).
CODEX_TIMEOUT_MS=0

# Auto-compact threshold (backward compatible with MAX_INPUT_TOKENS_BEFORE_RESET).
MAX_INPUT_TOKENS_BEFORE_COMPACT=250000

# Compact strategy:
# - hard: summarize then start a new Codex session (bot-managed compaction)
# - native: use Codex CLI auto compaction and continue in the same session
# - off: disable compact behavior
COMPACT_STRATEGY=hard

# Enable/disable threshold-triggered compact logic
COMPACT_ON_THRESHOLD=true

# Optional: native strategy limit passed to Codex as model_auto_compact_token_limit.
# Defaults to MAX_INPUT_TOKENS_BEFORE_COMPACT.
# MODEL_AUTO_COMPACT_TOKEN_LIMIT=250000

# true to include reasoning items in Discord output
SHOW_REASONING=false

# Print parsed events + stderr logs
DEBUG_EVENTS=false

# Live progress updates during long runs (edit a progress message in-place)
PROGRESS_UPDATES_ENABLED=true

# Heartbeat interval for progress message refresh (ms)
PROGRESS_UPDATE_INTERVAL_MS=15000

# Min gap between event-triggered progress refreshes (ms)
PROGRESS_EVENT_FLUSH_MS=5000

# Max preview chars for latest-step text in progress output
PROGRESS_TEXT_PREVIEW_CHARS=140

# Include non-JSON stdout lines in progress activity (captures Codex CLI chunked text output)
PROGRESS_INCLUDE_STDOUT=true

# Include raw stderr lines in progress latest-step preview (can be noisy)
PROGRESS_INCLUDE_STDERR=false

# Max plan item lines rendered in progress message/details
PROGRESS_PLAN_MAX_LINES=4

# Max completed key steps rendered in progress message/details
PROGRESS_DONE_STEPS_MAX=4

# Max recent activity lines rendered in progress/status output
PROGRESS_ACTIVITY_MAX_LINES=4

# Max total chars for each rendered progress message body
PROGRESS_MESSAGE_MAX_CHARS=1800

# Process-level self-healing (auto reconnect/relogin on runtime faults)
SELF_HEAL_ENABLED=true
SELF_HEAL_RESTART_DELAY_MS=5000
SELF_HEAL_MAX_LOGIN_BACKOFF_MS=60000

# Optional: auto-upgrade scheduler adapter
# AUTO_UPGRADE_SCHEDULER=auto|launchd|task-scheduler|none
# SCHEDULE_HOUR=5
# SCHEDULE_MINUTE=15
# LABEL=com.atou.codex-cli-auto-upgrade
# BOT_LABEL=com.atou.codex-discord-bot
# TASK_NAME=codex-cli-auto-upgrade
# BOT_TASK_NAME=codex-discord-bot
# CODEX_WINGET_ID=OpenAI.Codex
# CODEX_UPGRADE_COMMAND=
# CODEX_UPGRADE_CHECK_COMMAND=

# Optional proxy (e.g. Clash)
# Discord REST uses HTTP_PROXY (undici). Discord Gateway WS can use SOCKS_PROXY (needs patch, see README).
HTTP_PROXY=
SOCKS_PROXY=

# If your HTTP proxy does TLS MITM, set INSECURE_TLS=1 (NOT recommended)
INSECURE_TLS=0
